# ============================================================
# HollowPay — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# --- Neon PostgreSQL ---
DATABASE_URL="postgresql://user:password@host.neon.tech/hollowpay?sslmode=require"

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard/onboarding"

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="hollowpay-uploads"
R2_PUBLIC_URL="https://your-r2-public-url.example.com"

# --- Application ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HollowPay"

# --- Admin ---
# Clerk user ID of the platform founder/admin
ADMIN_CLERK_USER_ID="user_..."

# --- Notifications ---
# Founder notification email (operational alerts only)
FOUNDER_NOTIFICATION_EMAIL="zerodaycops@gmail.com"
